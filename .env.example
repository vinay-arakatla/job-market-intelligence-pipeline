# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=job_market_db
DB_USER=your_username
DB_PASSWORD=your_password

# JobSpy Configuration
JOBSPY_TIMEOUT=30
JOBSPY_MAX_RESULTS=500

# Airflow Configuration
AIRFLOW_HOME=./airflow
AIRFLOW__CORE__DAGS_FOLDER=./dags
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__UNIT_TEST_MODE=False

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/pipeline.log

# Pipeline Configuration
PIPELINE_RUN_INTERVAL_DAYS=1
SCRAPE_BATCH_SIZE=100

# Job Search Configuration
JOB_TITLES=Data Analyst,BI Analyst,Junior Data Engineer,SQL Developer,Power BI Analyst,Data Engineer Intern,Business Intelligence Developer
JOB_LOCATIONS=Berlin,Germany
JOB_PLATFORMS=linkedin,indeed,glassdoor,google

# Profile Configuration (for scoring)
PROFILE_SKILLS=SQL,Python,Apache Airflow,PostgreSQL,Power BI,Tableau,ETL,Data Validation,Dashboarding,Reporting,Oracle Database,Spark
GERMAN_LEVEL=B1
YEARS_EXPERIENCE=3

# Development
DEBUG=False
ENVIRONMENT=production
