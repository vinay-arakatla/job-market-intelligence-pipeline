# Environment Configuration for Job Market Intelligence Pipeline
# Copy this file to .env and update with your actual values

# ==================== Database Configuration ====================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=job_market_db
DB_USER=postgres
DB_PASSWORD=postgres

# ==================== Job Search Configuration ====================
# Job titles to search for (comma-separated)
JOB_TITLES=Data Analyst,BI Analyst,Junior Data Engineer,SQL Developer,Power BI Analyst,Data Engineer Intern,Business Intelligence Developer

# Locations to search (comma-separated)
JOB_LOCATIONS=Berlin,Germany

# Job platforms (comma-separated)
# Options: linkedin, indeed, glassdoor, google
JOB_PLATFORMS=linkedin,indeed,glassdoor,google

# ==================== JobSpy Configuration ====================
JOBSPY_TIMEOUT=30
JOBSPY_MAX_RESULTS=500

# ==================== Your Profile Configuration ====================
# Your technical skills (comma-separated)
PROFILE_SKILLS=SQL,Python,Apache Airflow,PostgreSQL,Power BI,Tableau,ETL,Data Validation,Dashboarding,Reporting,Oracle Database,Spark

# Your German language level (A1, A2, B1, B2, C1, C2)
GERMAN_LEVEL=B1

# Your years of experience
YEARS_EXPERIENCE=3

# ==================== Pipeline Configuration ====================
PIPELINE_RUN_INTERVAL_DAYS=1
SCRAPE_BATCH_SIZE=100

# ==================== Logging Configuration ====================
LOG_LEVEL=INFO
LOG_FILE=logs/pipeline.log

# ==================== Environment ====================
DEBUG=False
ENVIRONMENT=production
